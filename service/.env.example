PORT=3099
API_SECRET=replace-with-a-long-random-secret

DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_APPROVAL_CHANNEL_ID=
# Comma-separated role IDs. Members with any listed role can approve/deny.
DISCORD_APPROVER_ROLE_IDS=

GOOGLE_SPREADSHEET_ID=
# Recommended for Railway: copy these three fields from the service-account JSON.
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Alternatives for Railway or local hosting:
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=C:\\secure\\tsp-timeclock-service-account.json
ROSTER_SHEET_NAME=Membership Tracker
ROSTER_START_ROW=9
ROSTER_NAME_COLUMN=D
ROSTER_DISCORD_COLUMN=E
ROSTER_HOURS_COLUMN=G
# Optional audit tab. Leave disabled when Hours is only a column on the roster.
ENABLE_HOURS_AUDIT_LOG=false
HOURS_LOG_SHEET_NAME=Hours

# duration displays totals as 00:00:00. decimal writes values such as 2.25.
HOURS_VALUE_MODE=duration

# Railway volume mount should use /data. Local installs can omit this variable.
DATA_FILE=/data/sessions.json
